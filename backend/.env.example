FLASK_ENV=development
# Required in production/non-development. Leave unset locally for ephemeral dev keys.
APP_SECRET_KEY=
DATABASE_URL=sqlite:///elitez_events.db
ALLOW_DEMO_USER=0
STORAGE_PROVIDER=s3
STORAGE_BUCKET=elitez-events-assets
STORAGE_REGION=ap-southeast-1
MODEL_PROVIDER=gemini
# Set to gemini (default) or one of non_gemini/manual/disabled/off to skip LLM calls.
MODEL_NAME=gemini-1.5-pro
MODEL_API_BASE=https://generativelanguage.googleapis.com
# Primary LLM key. For Gemini, set GEMINI_API_KEY (preferred) or MODEL_API_KEY.
GEMINI_API_KEY=your-gemini-api-key-here
MODEL_API_KEY=replace-in-runtime
EXPORT_OUTPUT_DIR=./exports
AUDIT_LOG_LEVEL=info
# Must be set for non-local runtime (ex: https://api.example.com)
APP_BASE_URL=
SESSION_COOKIE_SECURE=0
# Semicolon-separated Flask-Limiter rules applied to POST /api/auth/login.
LOGIN_RATE_LIMIT=10 per minute;50 per hour
# Use Redis or another shared backend in multi-process production deployments.
RATELIMIT_STORAGE_URI=memory://
